# ===========================================
# Dan 1 — Token Vizualizator i Temperature Playground
# Kopirajte ovaj fajl u .env i popunite vrijednosti
# ===========================================

# DeepSeek API ključ (dobijate od predavača na početku Dana 2)
# Za Dan 1 možete koristiti Ollama kao fallback bez API ključa
DEEPSEEK_API_KEY=sk-vas-kljuc-ovdje

# Ollama konfiguracija (lokalni LLM server)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_SMALL=llama3.2:1b
OLLAMA_MODEL_MEDIUM=llama3.2:3b

# Aplikacija
APP_PORT=8001
APP_ENV=development
