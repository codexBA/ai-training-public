{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  // ─── Konekcija na bazu (opcija 1: gotov ConnectionString) ────────────────
  // "ConnectionStrings": {
  //   "DefaultConnection": "Server=localhost\\SQLEXPRESS;Database=StateStatisticsDB;Trusted_Connection=True;TrustServerCertificate=True;"
  // },

  // ─── Konekcija na bazu (opcija 2: individualne varijable, kao Python .env) ─
  "DB_SERVER": "localhost\\SQLEXPRESS",
  "DB_NAME": "StateStatisticsDB",
  "DB_TRUSTED_CONNECTION": "yes"

  // Ako koristite SQL Server autentifikaciju, postavite:
  // "DB_TRUSTED_CONNECTION": "no",
  // "DB_USER": "tvoj_korisnik",
  // "DB_PASSWORD": "tvoja_lozinka"
}
